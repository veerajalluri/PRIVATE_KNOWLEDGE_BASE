# ── LLM Providers (set whichever you use) ─────────────────────────────────────

# Claude (Anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Ollama (local) — default is http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434

# ── Confluence (required only for load_confluence.py) ─────────────────────────
CONFLUENCE_URL=https://yourcompany.atlassian.net
CONFLUENCE_EMAIL=you@example.com
CONFLUENCE_API_TOKEN=your_atlassian_api_token_here
CONFLUENCE_SPACE_KEYS=ENG,DOCS   # comma-separated; leave blank to sync all spaces
